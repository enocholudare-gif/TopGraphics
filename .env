# PostgreSQL Connection String (Update with your actual Neon/Supabase/Local DB URL)
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/topgraphics"

# Authentication Secret
# Run `openssl rand -base64 32` to generate a random secret
JWT_SECRET="generate-a-secure-random-string-here"

# Cloudinary Storage Credentials
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"